{
	"conf_version": "1.11.0",
	"rootDir": "./",
	"ensembl_ftp": "ftp.ensembl.org:21",
	"ensembl_ftp_json_path": "/pub/current_json",
	"ensembl_ftp_gff3_path": "/pub/current_gff3",
	"ensembl_ftp_mysql_path": "/pub/current_mysql",
	"ensembl_genomes_ftp": "ftp.ensemblgenomes.org:21",
	"ensembl_genomes_ftp_json_path": "/pub/current/$(branch)/json",
	"ensembl_genomes_ftp_gff3_path": "/pub/current/$(branch)/gff3",
	"ensembl_genomes_ftp_mysql_path": "/pub/current/$(branch)/mysql",
	"ensembl_genomes_ftp_meta_path": "/pub/current/species.txt",
	"ensembl_version_url": "http://rest.ensembl.org/info/eg_version?content-type=application/json",
	"httpPort": "9292",
	"grpcPort": "7777",
	"prodHttpPort": "9291",
	"prodGrpcPort": "7776",
	"keepChunks": "yes",
	"progressRefreshRate": "2",
	"kvgenCount": "4",
	"kvgenChunkSize": "20000000",
	"batchSize": "100000",
	"progressInterval": "5",
	"maxMappingResult": "75",
	"maxSearchResult": "50",
	"maxMappingResultLite": "100",
	"maxSearchResultLite": "50",
	"mapFilterTimeoutDuration": "300",
	"cacheMaxEntrySize": "25000",
	"cacheHardMaxSize": "1024",
	"disableCache": "n",
	"disableEnsemblReleaseCheck": "y",
	"disableRemoteConfigCheck": "y",
	"dbBackend": "lmdb",
	"lmdbSafetyFactor": "20",
	"lookupDbDir": "out_prod_v5/",
	"tmpRuneSize": "10000000",
	"mergeArraySize": "150000",
	"mergeCheckpointInterval": "100000",
	"__dbsnp_config_comment": "dbSNP bucket sort configuration options below",
	"dbsnpNumBuckets": "150",
	"dbsnpNumWorkers": "6",
	"dbsnpReverseXrefs": "yes",
	"dbsnpLookupXrefs": "yes",
	"__bucket_config_comment": "Bucket sort system configuration options below",
	"bucketEnabled": "yes",
	"bucketSortMethod": "unix",
	"compressBuckets": "yes",
	"bucketReadBufferSize": "524288",
	"bucketWriteBufferSize": "65536",
	"bucketSortWorkers": "8",
	"bucketConcatWorkers":"5",
	"keepBucketFiles": "no",
	"__unix_sort_config_comment": "Unix external sort configuration (bounded memory, good for large datasets like dbsnp)",
	"unixSortOptions": "-S 4G --parallel=4 -T /data2/tmp",
	"unixSortCompressor": "pigz",
	"__pubchem_config_comment": "PubChem retry configuration for network/corruption errors",
	"pubchemRetryCount": "4",
	"pubchemRetryWaitMinutes": "10",
	"__alphafold_config_comment": "AlphaFold PAE processing configuration",
	"paeWorkers": "8",
	"__cellxgene_config_comment": "CELLxGENE Census data extraction configuration",
	"cellxgeneExtractScript": "src/scripts/cellxgene/extract_cellxgene_data.py",
	"cellxgeneDataDir": "/data/bioyoda/snapshots/raw_data/cellxgene",
	"cellxgeneCensusVersion": "stable",
	"__patents_config_comment": "Patents data processing configuration - output path derived from source1.dataset.json",
	"patentsPrepareScript": "src/scripts/patents/patents_prepare.py",
	"patentsIncludeUSPTO": "yes",
	"includePatentAbstracts": "yes",
	"__clinical_trials_config_comment": "Clinical trials data processing configuration - output path derived from source1.dataset.json",
	"clinicalTrialsPrepareScript": "src/scripts/clinical_trials/clinical_trials_prepare.py",
	"__chembl_config_comment": "ChEMBL SQLite-based data extraction configuration",
	"chemblExtractScript": "src/scripts/chembl/extract_chembl_data.py",
	"chemblSqliteDb": "raw_data/chembl/chembl_36/chembl_36_sqlite/chembl_36.db"
}
