      "expected": {
        "should_find": true,
        "has_title": true
      }
    },
    {
      "name": "ID Lookup - Second Trial",
      "type": "id_lookup",
      "id": "@reference[1].nct_id",
      "expected": {
        "should_find": true,
        "has_title": true
      }
    },
    {
      "name": "ID Lookup - Third Trial",
      "type": "id_lookup",
      "id": "@reference[2].nct_id",
      "expected": {
        "should_find": true,
        "has_title": true
      }
