{
  "common_tests": [
    {
      "name": "Lookup by BAO ID",
      "type": "id_lookup",
      "id": "@reference[0].id"
    },
    {
      "name": "Check attributes present",
      "type": "attribute_check",
      "id": "@reference[0].id"
    },
    {
      "name": "Lookup multiple IDs",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "id"
    },
    {
      "name": "Invalid ID handling",
      "type": "invalid_id",
      "invalid_id": "BAO:9999999"
    }
  ],
  "custom_tests": [
    {
      "name": "Text search by name",
      "description": "Search for BAO terms by name keyword",
      "test_function": "test_text_search",
      "params": {
        "query": "fluorescence",
        "expected_dataset": "bao"
      }
    },
    {
      "name": "Text search by synonym",
      "description": "Search for BAO terms by synonym",
      "test_function": "test_text_search",
      "params": {
        "query": "FRET",
        "expected_dataset": "bao"
      }
    },
    {
      "name": "Parent navigation",
      "description": "Navigate to parent terms in ontology hierarchy",
      "test_function": "test_parent_navigation",
      "params": {
        "id": "BAO:0000001",
        "expected_parent_count": 1
      }
    },
    {
      "name": "Child navigation",
      "description": "Navigate to child terms in ontology hierarchy",
      "test_function": "test_child_navigation",
      "params": {
        "id": "BAO:0000001",
        "expected_child_count": 2
      }
    }
  ]
}
