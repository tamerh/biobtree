{
  "dataset": "biogrid",
  "description": "BioGRID protein-protein and genetic interaction database tests (dual dataset: biogrid summary + biogrid_interaction details)",
  "test_cases": [
    {
      "name": "basic_biogrid_lookup",
      "description": "Look up a BioGRID interactor summary by ID",
      "type": "search",
      "input": "112315",
      "expected": {
        "has_results": true,
        "dataset": "biogrid"
      }
    },
    {
      "name": "biogrid_summary_attributes",
      "description": "Verify BioGRID summary has statistics (no embedded interactions)",
      "type": "entry",
      "input": "112315",
      "dataset": "biogrid",
      "expected": {
        "has_attributes": true,
        "attribute_fields": ["biogrid_id", "interaction_count", "unique_partners", "physical_count", "genetic_count"]
      }
    },
    {
      "name": "biogrid_to_entrez",
      "description": "Map BioGRID interactor to Entrez Gene",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>entrez",
      "expected": {
        "has_results": true,
        "target_dataset": "entrez"
      }
    },
    {
      "name": "biogrid_to_uniprot",
      "description": "Map BioGRID interactor to UniProt",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>uniprot",
      "expected": {
        "has_results": true,
        "target_dataset": "uniprot"
      }
    },
    {
      "name": "biogrid_to_refseq",
      "description": "Map BioGRID interactor to RefSeq",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>refseq",
      "expected": {
        "has_results": true,
        "target_dataset": "refseq"
      }
    },
    {
      "name": "uniprot_to_biogrid",
      "description": "Map UniProt to BioGRID summary (reverse lookup)",
      "type": "mapping",
      "input": "P45985",
      "chain": ">>uniprot>>biogrid",
      "expected": {
        "has_results": true,
        "target_dataset": "biogrid"
      }
    },
    {
      "name": "biogrid_to_pubmed",
      "description": "Map BioGRID interactor to PubMed references",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>pubmed",
      "expected": {
        "has_results": true,
        "target_dataset": "pubmed"
      }
    },
    {
      "name": "biogrid_to_taxonomy",
      "description": "Map BioGRID interactor to taxonomy",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>taxonomy",
      "expected": {
        "has_results": true,
        "target_dataset": "taxonomy"
      }
    },
    {
      "name": "biogrid_to_interaction",
      "description": "Map BioGRID summary to biogrid_interaction details",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>biogrid_interaction",
      "expected": {
        "has_results": true,
        "target_dataset": "biogrid_interaction"
      }
    },
    {
      "name": "entrez_to_biogrid",
      "description": "Map Entrez Gene to BioGRID (reverse lookup)",
      "type": "mapping",
      "input": "6416",
      "chain": ">>entrez>>biogrid",
      "expected": {
        "has_results": true,
        "target_dataset": "biogrid"
      }
    },
    {
      "name": "biogrid_physical_filter",
      "description": "Filter BioGRID entries with physical interactions",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid[biogrid.physical_count > 0]",
      "expected": {
        "has_results": true
      }
    },
    {
      "name": "uniprot_to_biogrid_interaction",
      "description": "Map UniProt directly to biogrid_interaction (bypassing summary)",
      "type": "mapping",
      "input": "P45985",
      "chain": ">>uniprot>>biogrid_interaction",
      "expected": {
        "has_results": true,
        "target_dataset": "biogrid_interaction"
      }
    },
    {
      "name": "biogrid_interaction_to_pubmed",
      "description": "Map biogrid_interaction to PubMed",
      "type": "mapping",
      "input": "112315",
      "chain": ">>biogrid>>biogrid_interaction>>pubmed",
      "expected": {
        "has_results": true,
        "target_dataset": "pubmed"
      }
    },
    {
      "name": "biogrid_interaction_physical_filter",
      "description": "Filter biogrid_interaction by experimental_system_type",
      "type": "mapping",
      "input": "P45985",
      "chain": ">>uniprot>>biogrid_interaction[biogrid_interaction.experimental_system_type=='physical']",
      "expected": {
        "has_results": true
      }
    }
  ]
}
