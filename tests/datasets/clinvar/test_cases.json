{
  "common_tests": [
    {
      "name": "ID Lookup - First Variant",
      "type": "id_lookup",
      "id": "@reference[0].variation_id",
      "expected": {
        "should_find": true,
        "has_name": true
      }
    },
    {
      "name": "ID Lookup - Second Variant",
      "type": "id_lookup",
      "id": "@reference[1].variation_id",
      "expected": {
        "should_find": true,
        "has_name": true
      }
    },
    {
      "name": "ID Lookup - Third Variant",
      "type": "id_lookup",
      "id": "@reference[2].variation_id",
      "expected": {
        "should_find": true,
        "has_name": true
      }
    },
    {
      "name": "Variant with Type",
      "type": "attribute_check",
      "id": "@reference[0].variation_id",
      "attributes": ["type"]
    },
    {
      "name": "Variant with Clinical Significance",
      "type": "attribute_check",
      "id": "@reference[0].variation_id",
      "attributes": ["germline_classification"]
    },
    {
      "name": "Variant with Chromosome Location",
      "type": "attribute_check",
      "id": "@reference[0].variation_id",
      "attributes": ["chromosome", "start", "stop"]
    },
    {
      "name": "Variant with Gene Symbol",
      "type": "attribute_check",
      "id": "@reference[0].variation_id",
      "attributes": ["gene_symbol"]
    },
    {
      "name": "Multi-Lookup - Multiple Variants",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "variation_id"
    },
    {
      "name": "Invalid ID - Should Return Empty",
      "type": "invalid_id",
      "id": "99999999"
    }
  ]
}
