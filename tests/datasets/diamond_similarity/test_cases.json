{
  "dataset_name": "Protein Similarity",
  "description": "DIAMOND BLASTP protein sequence similarity data",
  "test_cases": [
    {
      "name": "Lookup protein by DIAMOND ID",
      "type": "lookup",
      "query": "{diamond_id}",
      "expected": {
        "found": true,
        "has_attributes": true
      }
    },
    {
      "name": "Check protein has similarities",
      "type": "attribute_exists",
      "query": "{diamond_id}",
      "attribute_path": "ProteinSimilarity.similarities",
      "expected": {
        "exists": true,
        "is_array": true
      }
    },
    {
      "name": "Check similarity count",
      "type": "attribute_exists",
      "query": "{diamond_id}",
      "attribute_path": "ProteinSimilarity.similarity_count",
      "expected": {
        "exists": true,
        "greater_than": 0
      }
    },
    {
      "name": "Verify top identity score",
      "type": "attribute_exists",
      "query": "{diamond_id}",
      "attribute_path": "ProteinSimilarity.top_identity",
      "expected": {
        "exists": true
      }
    },
    {
      "name": "Verify top bitscore",
      "type": "attribute_exists",
      "query": "{diamond_id}",
      "attribute_path": "ProteinSimilarity.top_bitscore",
      "expected": {
        "exists": true
      }
    }
  ]
}
