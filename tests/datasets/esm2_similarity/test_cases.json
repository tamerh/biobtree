{
  "common_tests": [
    {
      "name": "ID Lookup - First Protein",
      "type": "id_lookup",
      "id": "@reference[0].uniprot_id",
      "expected": {
        "should_find": true,
        "has_name": true
      }
    },
    {
      "name": "ID Lookup - Second Protein",
      "type": "id_lookup",
      "id": "@reference[1].uniprot_id",
      "expected": {
        "should_find": true,
        "has_name": true
      }
    },
    {
      "name": "Protein with Similarities",
      "type": "attribute_check",
      "id": "@reference[0].uniprot_id",
      "attributes": ["similarities"]
    },
    {
      "name": "Protein with Similarity Count",
      "type": "attribute_check",
      "id": "@reference[0].uniprot_id",
      "attributes": ["similarity_count"]
    },
    {
      "name": "Protein with Top Similarity",
      "type": "attribute_check",
      "id": "@reference[0].uniprot_id",
      "attributes": ["top_similarity"]
    },
    {
      "name": "Protein with Average Similarity",
      "type": "attribute_check",
      "id": "@reference[0].uniprot_id",
      "attributes": ["avg_similarity"]
    },
    {
      "name": "Multi-Lookup - Multiple Proteins",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "uniprot_id"
    },
    {
      "name": "Invalid ID - Should Return Empty",
      "type": "invalid_id",
      "id": "ZZZZZZZZZ"
    }
  ]
}
