{
  "common_tests": [
    {
      "name": "Lookup by HMDB ID",
      "type": "id_lookup",
      "id": "@reference[0].accession"
    },
    {
      "name": "Lookup by metabolite name",
      "type": "name_lookup",
      "name": "@reference[0].name"
    },
    {
      "name": "Lookup by synonym",
      "type": "alias_lookup",
      "alias": "@reference[0].synonyms.synonym[0]",
      "expected_id": "@reference[0].accession"
    },
    {
      "name": "Lookup by secondary accession",
      "type": "alias_lookup",
      "alias": "@reference[0].secondary_accessions.accession[0]",
      "expected_id": "@reference[0].accession"
    },
    {
      "name": "Check attributes present",
      "type": "attribute_check",
      "id": "@reference[0].accession"
    },
    {
      "name": "Lookup multiple IDs",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "accession"
    },
    {
      "name": "Case-insensitive name search",
      "type": "case_insensitive",
      "symbol": "@reference[0].name"
    },
    {
      "name": "Invalid ID handling",
      "type": "invalid_id",
      "invalid_id": "HMDB99999999"
    }
  ]
}
