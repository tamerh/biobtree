{
  "dataset_info": {
    "name": "STRING Protein Interactions",
    "version": "12.0",
    "organism": "Homo sapiens (9606)",
    "test_entries": 50,
    "description": "Protein-protein interaction networks with evidence channels"
  },
  "tests": [
    {
      "name": "string_basic_lookup",
      "description": "Basic STRING data lookup for a known UniProt protein",
      "type": "lookup",
      "identifier": "P27348",
      "dataset": "string",
      "expected": {
        "has_results": true,
        "min_results": 1
      }
    },
    {
      "name": "string_interactions_present",
      "description": "STRING entry should have interactions",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.interactions",
      "expected": {
        "exists": true,
        "min_length": 1
      }
    },
    {
      "name": "string_organism_taxid",
      "description": "STRING attributes should have organism taxonomy ID",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.organism_taxid",
      "expected": {
        "exists": true,
        "value": 9606
      }
    },
    {
      "name": "string_preferred_name",
      "description": "STRING attributes should have preferred protein name",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.preferred_name",
      "expected": {
        "exists": true,
        "not_empty": true
      }
    },
    {
      "name": "string_interaction_partner",
      "description": "Interactions should have partner UniProt IDs",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.interactions[0].partner",
      "expected": {
        "exists": true,
        "pattern": "^[A-Z0-9]+$"
      }
    },
    {
      "name": "string_interaction_score",
      "description": "Interactions should have combined score",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.interactions[0].score",
      "expected": {
        "exists": true,
        "min_value": 0,
        "max_value": 1000
      }
    },
    {
      "name": "string_evidence_experimental",
      "description": "Interactions may have experimental evidence flag",
      "type": "attribute_check",
      "identifier": "P27348",
      "dataset": "string",
      "attribute_path": "Attributes.Stringattr.interactions[0].has_experimental",
      "expected": {
        "exists": false
      }
    },
    {
      "name": "string_string_id_keyword_lookup",
      "description": "STRING ID should resolve to STRING entry via keyword",
      "type": "lookup",
      "identifier": "9606.ENSP00000331342",
      "dataset": "string",
      "expected": {
        "has_results": true,
        "min_results": 1
      }
    },
    {
      "name": "string_bidirectional_xref_to_uniprot",
      "description": "STRING entries should have xrefs to UniProt for mapping queries",
      "type": "xref_exists",
      "identifier": "9606.ENSP00000331342",
      "dataset": "string",
      "xref_dataset": "uniprot",
      "expected": {
        "has_xref": true,
        "min_count": 1
      }
    }
  ]
}