{
  "common_tests": [
    {
      "name": "Lookup by patent number",
      "type": "id_lookup",
      "id": "@reference[0].patent_number"
    },
    {
      "name": "Check attributes present",
      "type": "attribute_check",
      "id": "@reference[0].patent_number"
    },
    {
      "name": "Check patent family cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].patent_number",
      "xref_type": "patent_family",
      "expected": "@reference[0].family_id"
    },
    {
      "name": "Check IPC code cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].patent_number",
      "xref_type": "ipc",
      "expected": "A61K 31/41"
    },
    {
      "name": "Check CPC code cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].patent_number",
      "xref_type": "cpc",
      "expected": "C07D 231/12"
    },
    {
      "name": "Check assignee cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].patent_number",
      "xref_type": "assignee",
      "expected": "EI DU PONT DE NEMOURS"
    },
    {
      "name": "Check patent-compound cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].patent_number",
      "xref_type": "patent_compound",
      "expected": "@reference[0].compound_ids[0]"
    },
    {
      "name": "Lookup multiple patents",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "patent_number"
    },
    {
      "name": "Invalid patent ID handling",
      "type": "invalid_id",
      "invalid_id": "US-99999999-A"
    }
  ]
}
