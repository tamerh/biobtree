{
  "common_tests": [
    {
      "name": "Lookup by UniProt ID",
      "type": "id_lookup",
      "id": "@reference[0].primaryAccession"
    },
    {
      "name": "Check attributes present",
      "type": "attribute_check",
      "id": "@reference[0].primaryAccession"
    },
    {
      "name": "Check EMBL cross-reference",
      "type": "xref_exists",
      "id": "@reference[0].primaryAccession",
      "xref_type": "EMBL",
      "expected": "AY261360"
    },
    {
      "name": "Check RefSeq cross-reference",
      "type": "xref_exists",
      "id": "@reference[4].primaryAccession",
      "xref_type": "RefSeq",
      "expected": "NP_042841"
    },
    {
      "name": "Check GO cross-reference",
      "type": "xref_exists",
      "id": "@reference[17].primaryAccession",
      "xref_type": "GO",
      "expected": "GO:0005886"
    },
    {
      "name": "Lookup by UniProt name",
      "type": "alias_lookup",
      "alias": "@reference[0].uniProtkbId",
      "expected_id": "@reference[0].primaryAccession"
    },
    {
      "name": "Lookup multiple IDs",
      "type": "multi_lookup",
      "count": 3,
      "id_field": "primaryAccession"
    },
    {
      "name": "Invalid ID handling",
      "type": "invalid_id",
      "invalid_id": "INVALID99999"
    }
  ],
  "custom_tests": []
}
